---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/index.css';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Isaure Lohest',
    jobTitle: 'AI Integration Engineer',
    url: 'https://ai.isaure-lohest.com/',
    image: 'https://ai.isaure-lohest.com/favicon.png',
    sameAs: ['https://isaure-lohest.com/'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Isaure Lohest — AI Integration Engineer',
    url: 'https://ai.isaure-lohest.com/',
    description:
      'AI integration engineering portfolio focused on SaaS workflows, messaging systems, CRM enrichment, and operational automation.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Isaure Lohest — AI Integration Engineer',
    url: 'https://ai.isaure-lohest.com/',
    description:
      'I build AI systems inside SaaS products, admin flows, CRMs, and messaging stacks — integrated into the way your product actually runs.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://ai.isaure-lohest.com/',
    },
  },
];
---
<BaseLayout
  title="Isaure Lohest — AI Integration Engineer"
  description="I build AI systems inside SaaS products, admin flows, CRMs, and messaging stacks — integrated into the way your product actually runs."
  canonicalUrl="https://ai.isaure-lohest.com/"
  structuredData={structuredData}
>
  <Fragment slot="head">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
  </Fragment>
<!-- ── NAVIGATION ───────────────────────────────────────────── -->
    <nav id="nav">
      <a href="#" class="nav-logo">Isaure Lohest</a>
      <div class="nav-links">
        <a href="#what">Services</a>
        <a href="#cases">Use cases</a>
        <a href="#process">Process</a>
        <a href="/walkthroughs/">Walkthroughs</a>
        <a href="#contact" class="nav-cta">Let's talk</a>
      </div>
      <!-- Mobile: pill compact -->
      <div class="nav-mobile">
        <button class="nav-menu-btn" id="nav-menu-btn" aria-label="Open menu" aria-expanded="false">
          <svg class="hamburger-icon" viewBox="0 0 24 24" aria-hidden="true">
            <line class="bar bar-top" x1="3" y1="7" x2="21" y2="7"/>
            <line class="bar bar-mid" x1="3" y1="12" x2="21" y2="12"/>
            <line class="bar bar-bot" x1="3" y1="17" x2="21" y2="17"/>
          </svg>
        </button>
        <a href="#contact" class="nav-cta nav-cta-mobile">Let's talk</a>
      </div>
    </nav>
    <!-- Close button: outside the drawer so it's above the opacity transition -->
    <button class="nav-drawer-close" id="nav-drawer-close" aria-label="Close menu" aria-hidden="true">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
    <!-- Mobile drawer -->
    <div class="nav-drawer" id="nav-drawer" aria-hidden="true" role="dialog" aria-label="Navigation">
      <nav class="nav-drawer-links">
        <a href="#what">Services</a>
        <a href="#cases">Use cases</a>
        <a href="#process">Process</a>
        <a href="/walkthroughs/">Walkthroughs</a>
      </nav>
      <a href="#contact" class="nav-drawer-cta">Let's talk →</a>
    </div>
    <button
      type="button"
      class="palette-toggle"
      id="palette-toggle"
      aria-label="Switch to light palette"
      aria-pressed="false"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 3v2.2" />
        <path d="M12 18.8V21" />
        <path d="M3 12h2.2" />
        <path d="M18.8 12H21" />
        <path d="M5.64 5.64 7.2 7.2" />
        <path d="M16.8 16.8l1.56 1.56" />
        <path d="M18.36 5.64 16.8 7.2" />
        <path d="M7.2 16.8l-1.56 1.56" />
        <path d="M12 8.2a3.8 3.8 0 1 1 0 7.6 3.8 3.8 0 0 1 0-7.6z" />
      </svg>
    </button>
    <a href="#" class="corner-wordmark" aria-label="Back to top">
      <svg viewBox="0 0 560 230" role="img">
        <defs>
          <path
            id="corner-wordmark-path"
            d="M 58 560 L 58 480 C 58 400 58 300 58 220 C 58 220 58 220 58 220 L 58 220"
          />
        </defs>
        <text>
          <textPath href="#corner-wordmark-path" startOffset="0%">
            isaure lohest.
          </textPath>
        </text>
      </svg>
    </a>

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <div id="hero-wrapper">
      <div id="hero">
        <canvas id="starfield"></canvas>
        <div class="hero-vignette"></div>
        <div class="hero-glow"></div>
        <div id="stickers"></div>

        <div class="hero-content">
          <!-- ── PHASE 1 : Sphere + title ─────────────────────── -->
          <div class="hero-phase-1" id="hero-phase-1">
            <h1 class="hero-title">
              Your product.<br />
              <em>Smarter.</em>
            </h1>
            <p class="hero-sub">
              AI integrated into the way your product actually runs. No new
              tools. Just more leverage.
            </p>
          </div>
        </div>

        <!-- ── AI Solution Explorer: appears after the hero copy exits ── -->
        <section
          class="explorer-layer"
          id="ai-explorer"
          aria-label="AI Solution Explorer"
        >
          <div class="explorer">
            <div class="explorer-header">
              <span class="explorer-header-text"
                >Every product has workflows that can be improved with AI.</span
              >
              <span class="explorer-header-sep">→</span>
              <span class="explorer-header-cta"> Describe yours</span>
            </div>

            <div class="chips" aria-label="Example questions">
              <button
                class="chip"
                type="button"
                data-q="Add AI to my SaaS admin flow"
              >
                Add AI to my SaaS admin flow
              </button>
              <button
                class="chip"
                type="button"
                data-q="Notify my team on Telegram when risk appears"
              >
                Notify my team on Telegram
              </button>
              <button
                class="chip"
                type="button"
                data-q="Automate WhatsApp follow-ups"
              >
                Automate WhatsApp follow-ups
              </button>
              <button
                class="chip"
                type="button"
                data-q="Summarize documents inside my admin"
              >
                Summarize documents in my admin
              </button>
              <button
                class="chip"
                type="button"
                data-q="Prioritize leads before sales opens the CRM"
              >
                Prioritize leads before sales opens the CRM
              </button>
            </div>

            <form class="explorer-form" id="explorer-form">
              <input
                type="text"
                id="explorer-input"
                class="explorer-input"
                placeholder="Ask what AI should do inside your product..."
                autocomplete="off"
              />
              <button
                type="submit"
                class="explorer-submit"
                aria-label="Explore this AI solution"
              >
                →
              </button>
            </form>

            <div
              id="explorer-response"
              class="explorer-response hidden"
              aria-live="polite"
            ></div>
          </div>
        </section>

        <div class="scroll-hint">
          <span>Scroll</span>
          <div class="scroll-line"></div>
        </div>
      </div>
    </div>

    <!-- ── SECTION 1: WHAT I BUILD ──────────────────────────────── -->
    <section id="what">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Services</span>
          <h2 class="section-title">AI, applied inside your product</h2>
          <p class="section-sub">
            AI is no longer optional: it is now part of how modern products
            operate. I build systems that improve workflows — sometimes visible
            to users, often running quietly in the background.
          </p>
        </div>
        <div class="services-grid">
          <div class="service-card">
            <div class="service-icon" aria-hidden="true">
              <svg viewBox="0 0 40 40">
                <path
                  class="icon-float"
                  d="M9 11c6-2 16-2 22 0 2 1 3 3 2 6-1 4-1 8 0 12 1 2-1 4-3 4-7-1-14-1-21 0-2 0-4-2-3-5 1-5 1-10 0-14 0-1 1-2 3-3z"
                />
                <path
                  class="icon-slide"
                  d="M12 17c4-1 8-1 12 0M12 23c5-1 10-1 16 1"
                />
                <circle class="icon-pulse" cx="29" cy="16" r="2.5" />
              </svg>
            </div>
            <h3>AI inside SaaS</h3>
            <p>
              Turn admin flows and dashboards into places where work gets
              summarized, classified, and acted on faster.
            </p>
            <ul>
              <li>Account summaries inside dashboards</li>
              <li>Admin insights from live product data</li>
              <li>Contextual actions inside your UI</li>
              <li>Automatic classification of incoming records</li>
            </ul>
          </div>
          <div class="service-card">
            <div class="service-icon" aria-hidden="true">
              <svg viewBox="0 0 40 40">
                <path
                  class="icon-float"
                  d="M8 13c4-4 13-5 20-3 6 2 8 8 5 13-3 5-11 7-18 5-3 2-6 3-8 3 1-2 2-4 2-6-4-4-4-9-1-12z"
                />
                <path
                  class="icon-slide"
                  d="M15 17c4-1 8-1 11 0M14 22c5 1 10 1 14-1"
                />
                <path
                  class="icon-pulse"
                  d="M29 9c1-2 2-3 4-4M32 14c2 0 4 0 5 1"
                />
              </svg>
            </div>
            <h3>Messaging integrations</h3>
            <p>
              Send the right alert, context, and next action to the channel your
              team already watches.
            </p>
            <ul>
              <li>Telegram alerts from product events</li>
              <li>WhatsApp follow-ups and confirmations</li>
              <li>AI-ranked incidents and summaries</li>
              <li>Approval flows with action buttons</li>
            </ul>
          </div>
          <div class="service-card">
            <div class="service-icon" aria-hidden="true">
              <svg viewBox="0 0 40 40">
                <path class="icon-slide" d="M8 13c6-3 12-2 17 3 3 3 5 4 8 3" />
                <path class="icon-slide" d="M8 27c6 3 12 2 17-3 3-3 5-4 8-3" />
                <circle class="icon-pulse" cx="11" cy="13" r="3" />
                <circle class="icon-pulse" cx="29" cy="20" r="3" />
                <circle class="icon-pulse" cx="11" cy="27" r="3" />
              </svg>
            </div>
            <h3>Workflow automation</h3>
            <p>
              Move repetitive decisions out of queues and into reliable
              AI-assisted pipelines.
            </p>
            <ul>
              <li>Document extraction on upload</li>
              <li>Request routing and triage</li>
              <li>CRM enrichment from real signals</li>
              <li>Scheduled reports your team can act on</li>
            </ul>
          </div>
          <div class="service-card">
            <div class="service-icon" aria-hidden="true">
              <svg viewBox="0 0 40 40">
                <path
                  class="icon-float"
                  d="M17 9c7-1 13 4 13 11 0 6-5 11-12 11-6 0-11-4-11-10 0-6 4-11 10-12z"
                />
                <path class="icon-slide" d="M26 28c3 2 5 4 7 7" />
                <path
                  class="icon-pulse"
                  d="M14 17c2-2 6-3 9-1M13 22c4 2 8 2 11 0"
                />
                <circle class="icon-pulse" cx="22" cy="16" r="1.5" />
              </svg>
            </div>
            <h3>Custom AI tools</h3>
            <p>
              Give teams focused internal tools that answer, draft, search, and
              route using your real data.
            </p>
            <ul>
              <li>Internal knowledge retrieval</li>
              <li>Support and operations copilots</li>
              <li>Call and meeting takeaways</li>
              <li>Drafts grounded in customer context</li>
            </ul>
          </div>
        </div>
        <div class="services-footer-cta">
          <div class="services-footer-copy">
            <span class="services-footer-label">Let&apos;s talk</span>
            <h3 class="services-footer-title">
              Want to integrate AI services into your product?
            </h3>
            <p>
              I build AI features that fit into real products, workflows, and
              operations. If you already have a use case in mind, let&apos;s talk
              about what to ship first.
            </p>
          </div>
          <a
            href="#contact"
            class="services-footer-link"
            data-cursor-contrast="difference"
          >
            Discuss your AI integration
          </a>
        </div>
      </div>
    </section>

    <!-- ── SECTION 2: USE CASES ──────────────────────────────────── -->
    <section id="cases">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Use cases</span>
          <h2 class="section-title">Use cases that ship</h2>
          <p class="section-sub">
            These systems don’t replace teams — they increase their output and
            decision quality.
          </p>
        </div>
        <div class="cases-board">
          <div class="cases-grid">
            <div class="case-card" data-tags="#routing #triage">
              <span class="case-tag">Workflow · Routing</span>
              <h3>Smart request routing and triage</h3>
              <div class="case-row">
                <div class="case-row-item">
                  <div class="label">Problem</div>
                  <p>
                    Incoming legal requests need to be understood, qualified,
                    and assigned to the right lawyer quickly.
                  </p>
                </div>
                <div class="case-row-item">
                  <div class="label">What the system does</div>
                  <p>
                    AI analyzes the client’s case, extracts the legal context,
                    evaluates urgency and complexity, and matches the request to
                    the most relevant lawyer based on expertise and past cases.
                  </p>
                </div>
                <div class="case-row-item case-outcome">
                  <div class="label">Business outcome</div>
                  <p>
                    Clients are routed faster, assignments are more relevant,
                    and legal teams spend less time on manual triage.
                  </p>
                </div>
              </div>
            </div>

            <div class="case-card" data-tags="#docs #parse">
              <span class="case-tag">Documents · AI</span>
              <h3>Uploaded document analysis</h3>
              <div class="case-row">
                <div class="case-row-item">
                  <div class="label">Problem</div>
                  <p>
                    Rental application files contain multiple documents that
                    take time to review manually.
                  </p>
                </div>
                <div class="case-row-item">
                  <div class="label">What the system does</div>
                  <p>
                    AI reads the dossier, extracts key financial and profile
                    information, flags inconsistencies or risk signals, and
                    suggests the next action, including whether to accept or
                    refuse the file and how to draft the client follow-up.
                  </p>
                </div>
                <div class="case-row-item case-outcome">
                  <div class="label">Business outcome</div>
                  <p>
                    Teams review applications faster, with clearer signals, more
                    consistent decisions, and less manual back-and-forth after
                    the review.
                  </p>
                </div>
              </div>
            </div>

            <div class="case-card" data-tags="#leads #score">
              <span class="case-tag">Data · CRM</span>
              <h3>Lead scoring and CRM enrichment</h3>
              <div class="case-row">
                <div class="case-row-item">
                  <div class="label">Problem</div>
                  <p>
                    Sales teams waste time reviewing weak inbound requests while
                    high-value leads wait too long.
                  </p>
                </div>
                <div class="case-row-item">
                  <div class="label">What the system does</div>
                  <p>
                    AI qualifies the lead, scores urgency and fit, surfaces the
                    key signals, and suggests the next best action before anyone
                    opens the CRM.
                  </p>
                </div>
                <div class="case-row-item case-outcome">
                  <div class="label">Business outcome</div>
                  <p>
                    Teams respond faster to the right opportunities and spend
                    less time sorting inbound demand.
                  </p>
                </div>
              </div>
            </div>

            <div class="case-card" data-tags="#content #structured-data">
              <span class="case-tag">Content · AI</span>
              <h3>Unstructured content into structured product data</h3>
              <div class="case-row">
                <div class="case-row-item">
                  <div class="label">Problem</div>
                  <p>
                    User-generated content is hard to search, organize, and
                    reuse when it stays unstructured.
                  </p>
                </div>
                <div class="case-row-item">
                  <div class="label">What the system does</div>
                  <p>
                    AI turns a simple food image into structured product
                    content: title, description, ingredients, tags, and a
                    ready-to-save recipe entry.
                  </p>
                </div>
                <div class="case-row-item case-outcome">
                  <div class="label">Business outcome</div>
                  <p>
                    Platforms gain cleaner content, better discovery, and more
                    reusable data without manual formatting.
                  </p>
                </div>
              </div>
            </div>

            <div class="case-card" data-tags="#search #knowledge">
              <span class="case-tag">Search · Knowledge</span>
              <h3>Semantic search in internal knowledge</h3>
              <div class="case-row">
                <div class="case-row-item">
                  <div class="label">Problem</div>
                  <p>
                    The answer exists somewhere, but teams still interrupt each
                    other to find it.
                  </p>
                </div>
                <div class="case-row-item">
                  <div class="label">What the system does</div>
                  <p>
                    A retrieval layer searches your knowledge base and returns
                    the most relevant answer with source context.
                  </p>
                </div>
                <div class="case-row-item case-outcome">
                  <div class="label">Business outcome</div>
                  <p>
                    Teams find answers faster. Onboarding and support depend
                    less on tribal knowledge.
                  </p>
                </div>
              </div>
            </div>

            <div class="case-card" data-tags="#support #admin">
              <span class="case-tag">SaaS · Dashboard</span>
              <h3>Support copilot in your admin</h3>
              <div class="case-row">
                <div class="case-row-item">
                  <div class="label">Problem</div>
                  <p>
                    Support teams lose time reading history before every reply.
                  </p>
                </div>
                <div class="case-row-item">
                  <div class="label">What the system does</div>
                  <p>
                    AI reads the thread, account history, and open tickets, then
                    drafts the next response with the right context.
                  </p>
                </div>
                <div class="case-row-item case-outcome">
                  <div class="label">Business outcome</div>
                  <p>
                    Faster replies. Less context switching. Agents review
                    instead of starting from zero.
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="case-detail" id="case-detail" aria-live="polite"></div>
        </div>
        <div class="cases-footer-cta">
          <div class="cases-footer-copy">
            <span class="cases-footer-label">Walkthroughs</span>
            <h3 class="cases-footer-title">See the interfaces in full scale</h3>
          </div>
          <a
            href="/walkthroughs"
            class="cases-footer-link"
          >
            Open AI product walkthroughs
          </a>
        </div>
      </div>
    </section>

    <!-- ── SECTION 3: PROCESS ────────────────────────────────────── -->
    <section id="process">
      <div class="process-layout">
        <div class="process-sticky">
          <div class="section-header">
            <span class="section-tag">Process</span>
            <h2 class="section-title">How I approach a project</h2>
            <p class="section-sub">
              Most AI projects fail because they start from tools instead of
              workflows. The work starts with the process, then becomes a stable
              system your team can use.
            </p>
            <br />
            <p class="section-sub">
              The goal is not to add AI — but to improve how the system already
              works.
            </p>
          </div>
        </div>
        <div class="process-steps">
          <div class="step">
            <span class="step-bg-icon" aria-hidden="true">
              <svg viewBox="0 0 160 160">
                <path
                  class="svg-frame"
                  d="M38 51c18-5 54-6 79-2 9 2 13 7 11 16-1 10-1 20 1 30 1 7-3 11-11 11-23-1-51 1-76-2-7-1-11-5-10-12 2-10 2-20 0-31-1-5 1-8 6-10z"
                />
                <path
                  class="svg-lines"
                  d="M49 65c10-2 19-2 29 0M48 79c16-3 35-2 53 1M50 93c11-2 25-1 36 1"
                />
                <path
                  class="svg-sparks"
                  d="M112 49c1-4 1-7 0-10M126 63c3-1 6-1 9 0M112 100c2 3 2 6 1 9M34 75c-3-1-6-1-9 0"
                />
              </svg>
            </span>
            <div class="step-num">01</div>
            <h3>Understand the workflow</h3>
            <p>
              Map the product logic, data flows, and handoffs before choosing
              any model or tool.
            </p>
          </div>
          <div class="step">
            <span class="step-bg-icon" aria-hidden="true">
              <svg viewBox="0 0 160 160">
                <path
                  class="svg-outer"
                  d="M78 24c18 13 36 32 53 55-14 22-31 41-51 57-19-14-37-33-52-55 13-21 31-41 50-57z"
                />
                <path
                  class="svg-inner"
                  d="M80 49c10 8 20 19 28 31-7 12-17 23-28 32-11-8-21-19-28-32 7-12 17-23 28-31z"
                />
                <path
                  class="svg-axis"
                  d="M80 24c2 8 2 16 0 24M132 80c-8 2-16 2-24 0M80 136c-2-8-2-16 0-24M28 80c8-2 16-2 24 0"
                />
              </svg>
            </span>
            <div class="step-num">02</div>
            <h3>Identify high-value opportunities</h3>
            <p>
              Find the few touchpoints where AI removes work, surfaces signal,
              or improves decision quality.
            </p>
          </div>
          <div class="step">
            <span class="step-bg-icon" aria-hidden="true">
              <svg viewBox="0 0 160 160">
                <path
                  class="svg-node svg-node-a"
                  d="M54 51c-1-10 8-18 18-16 9 2 14 10 12 19-2 8-9 13-16 13H55c-1-5-1-10-1-16z"
                />
                <path
                  class="svg-node svg-node-b"
                  d="M106 51c1-10-8-18-18-16-9 2-14 10-12 19 2 8 9 13 16 13h13c1-5 1-10 1-16z"
                />
                <path
                  class="svg-node svg-node-c"
                  d="M54 109c-1 10 8 18 18 16 9-2 14-10 12-19-2-8-9-13-16-13H55c-1 5-1 10-1 16z"
                />
                <path
                  class="svg-node svg-node-d"
                  d="M106 109c1 10-8 18-18 16-9-2-14-10-12-19 2-8 9-13 16-13h13c1 5 1 10 1 16z"
                />
                <path
                  class="svg-core"
                  d="M72 67c5-1 11-1 16 1 1 8 1 16 0 25-5 2-11 2-17 0-1-9-1-18 1-26z"
                />
              </svg>
            </span>
            <div class="step-num">03</div>
            <h3>Design the product logic</h3>
            <p>
              Define inputs, outputs, fallbacks, and the exact UX your team or
              users will rely on.
            </p>
          </div>
          <div class="step">
            <span class="step-bg-icon" aria-hidden="true">
              <svg viewBox="0 0 160 160">
                <path
                  class="svg-orbit"
                  d="M80 30c25 0 48 19 50 45 2 30-20 54-49 55-28 1-51-19-52-48-1-28 21-52 51-52z"
                />
                <path
                  class="svg-plus"
                  d="M80 54c2 16 1 35 0 52M54 80c15-2 35-2 52 0"
                />
                <path
                  class="svg-corners"
                  d="M38 42c-5-4-10-9-14-14M122 42c5-4 10-9 14-14M38 118c-5 4-10 9-14 14M122 118c5 4 10 9 14 14"
                />
              </svg>
            </span>
