          },

          summary: {
            match: /summar|briefing|digest|report|meeting|call|transcript/i,
            title: "Automated summaries and briefings",
            build: [
              "A briefing system that reads key data on schedule or trigger",
              "Structured summaries written for each team's operating context",
              "Delivery through dashboard, email, or Telegram",
            ],
            workflow: [
              "Define the data sources and decision points",
              "Connect through API or database query",
              "Generate summaries with a consistent output schema",
              "Send the briefing where the team already checks",
            ],
            tools: [
              "LLM with structured output",
              "Your data sources / APIs",
              "Cron / scheduler",
              "Email, or Telegram",
            ],
            outcome: [
              "Stakeholders start with the signal, not another dashboard review",
              "Anomalies surface before they get buried",
            ],
          },

          search: {
            match: /search|semantic|knowledge|find|retriev|rag/i,
            title: "Semantic search in your knowledge base",
            build: [
              "A search layer that makes existing knowledge usable on demand",
              "Semantic retrieval your team or product can query",
              "Optional natural-language access for internal knowledge",
            ],
            workflow: [
              "Ingest documents, wikis, and structured knowledge",
              "Store embeddings in the right retrieval layer",
              "Assemble context with ranking and source references",
              "Expose search inside the product or internal tool",
            ],
            tools: [
              "LLM for embeddings + generation",
              "Vector DB (pgvector / Pinecone)",
              "Your content sources",
              "RAG architecture",
            ],
            outcome: [
              "Teams find answers without interrupting each other",
              "Onboarding and support depend less on tribal knowledge",
            ],
          },

          workflow: {
            match:
              /workflow|automat|process|pipeline|trigger|route|triage|classif/i,
            title: "Intelligent workflow automation",
            build: [
              "An event-driven pipeline that handles incoming work automatically",
              "Classification, prioritization, and routing built into the flow",
              "Escalation and human review where risk requires it",
            ],
            workflow: [
              "Map inputs, decisions, owners, and outputs",
              "Identify where AI should classify, generate, or route",
              "Build fallbacks and error handling before deployment",
              "Connect the flow to existing tools through API or webhook",
            ],
            tools: [
              "LLM for classification / generation",
              "Your product API or CRM",
              "Webhook infrastructure",
              "Notification layer",
            ],
            outcome: [
              "High-volume work moves without manual sorting",
              "Handling stays consistent when volume increases",
            ],
          },

          admin: {
            match:
              /admin|dashboard|back.?office|internal tool|backoffice|ops team/i,
            title: "AI inside your admin panel",
            build: [
              "Inline AI features inside the admin your team already uses",
              "Generation, classification, and lookup with real product context",
              "An internal assistant shaped around your data model and workflows",
            ],
            workflow: [
              "Identify the admin tasks that slow the team down",
              "Choose the right interaction: suggestion, generation, or search",
              "Connect to the admin data layer without rebuilding the UI",
              "Ship the feature as part of the existing workflow",
            ],
            tools: [
              "LLM API",
              "Your existing admin stack (Nuxt, Next, custom)",
              "Your database / API",
              "Vector DB for RAG (optional)",
            ],
            outcome: [
              "Ops and support teams move faster on repeated work",
              "AI uses live product context, not a stale snapshot",
            ],
          },

          default: {
            match: null,
            title: "AI integration for your product",
            build: [
              "An AI system connected to your real data and workflows",
              "Pipelines that classify, summarize, route, or generate structured output",
              "Results surfaced inside the tools your team already uses",
            ],
            workflow: [
              "Map the workflow and identify where delay is costing time",
              "Design the AI layer with clear inputs and outputs",
              "Build on top of your existing stack and data",
              "Test on real cases before deployment",
            ],
            tools: [
              "OpenAI / Anthropic API",
              "Your existing backend",
              "Webhook infrastructure",
              "Vector DB (optional)",
            ],
            outcome: [
              "AI works inside the existing operating flow",
              "Manual effort drops on the tasks that repeat most",
            ],
          },
        };

        function getResponse(query) {
          const keys = Object.keys(RESPONSES).filter((k) => k !== "default");
          for (const key of keys) {
            if (RESPONSES[key].match && RESPONSES[key].match.test(query)) {
              return normalizeExplorerResponse(RESPONSES[key]);
            }
          }
          return normalizeExplorerResponse(RESPONSES.default);
        }

        function normalizeExplorerResponse(raw) {
          if (!raw) return normalizeExplorerResponse(RESPONSES.default);
          return {
            what:
              raw.what ||
              (raw.build && raw.build[0]) ||
              RESPONSES.default.build[0],
            workflow: Array.isArray(raw.workflow)
              ? raw.workflow.slice(0, 5)
              : RESPONSES.default.workflow,
            integrations: Array.isArray(raw.integrations)
              ? raw.integrations.slice(0, 6)
              : raw.tools || RESPONSES.default.tools,
            impact: Array.isArray(raw.impact)
              ? raw.impact.slice(0, 5)
              : raw.outcome || RESPONSES.default.outcome,
          };
        }

        function escapeHtml(value) {
          return String(value)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
        }

        function renderLoading() {
          return `<div class="explorer-loading">
        <div class="loading-dots"><span></span><span></span><span></span></div>
        <span>Designing the system…</span>
      </div>`;
        }

        function renderResponse(r) {
          const data = normalizeExplorerResponse(r);
          const flowItems = data.workflow
            .map((w) => `<li>${escapeHtml(w)}</li>`)
            .join("");
          const toolTags = data.integrations
            .map((t) => `<span class="tag">${escapeHtml(t)}</span>`)
            .join("");
          const impactItems = data.impact
            .map((o) => `<li>${escapeHtml(o)}</li>`)
            .join("");

          return `
        <div class="response-grid">
          <div class="response-block">
            <div class="response-block-label">What I can build</div>
            <p class="response-line">${escapeHtml(data.what)}</p>
          </div>
          <div class="response-block">
            <div class="response-block-label">Typical workflow</div>
            <ul>${flowItems}</ul>
          </div>
          <div class="response-block">
            <div class="response-block-label">Integrations</div>
            <div class="tags-row">${toolTags}</div>
          </div>
          <div class="response-block">
            <div class="response-block-label">Business impact</div>
            <ul>${impactItems}</ul>
          </div>
        </div>
        <button class="try-another" type="button" id="try-another">Try another use case</button>
      `;
        }

        const explorerForm = document.getElementById("explorer-form");
        const explorerInput = document.getElementById("explorer-input");
        const explorerResponse = document.getElementById("explorer-response");
        const placeholders = [
          "Ask what AI should do inside your product...",
          "Summarize uploaded documents in my admin",
          "Notify my team on Telegram when it matters",
          "Classify and prioritize incoming leads",
        ];
        let placeholderIndex = 0;
        let placeholderText = "";
        let placeholderCharIndex = 0;
        let isDeletingPlaceholder = false;
        let placeholderTimeout = null;

        function shouldPausePlaceholder() {
          return (
            document.activeElement === explorerInput ||
            explorerInput.value.trim()
          );
        }

        function typePlaceholder() {
          window.clearTimeout(placeholderTimeout);

          if (shouldPausePlaceholder()) {
            placeholderTimeout = window.setTimeout(typePlaceholder, 300);
            return;
          }

          const current = placeholders[placeholderIndex];
          if (isDeletingPlaceholder) {
            placeholderCharIndex = Math.max(0, placeholderCharIndex - 1);
          } else {
            placeholderCharIndex = Math.min(
              current.length,
              placeholderCharIndex + 1,
            );
          }

          placeholderText = current.slice(0, placeholderCharIndex);
          explorerInput.placeholder =
            placeholderText +
            (placeholderCharIndex < current.length ? "|" : "");

          let delay = isDeletingPlaceholder ? 34 : 58;

          if (
            !isDeletingPlaceholder &&
            placeholderCharIndex === current.length
          ) {
            delay = 1400;
            isDeletingPlaceholder = true;
          } else if (isDeletingPlaceholder && placeholderCharIndex === 0) {
            placeholderIndex = (placeholderIndex + 1) % placeholders.length;
            isDeletingPlaceholder = false;
            delay = 260;
          } else if (isDeletingPlaceholder) {
            delay = 22 + Math.random() * 34;
          } else {
            const lastChar = current[placeholderCharIndex - 1] || "";
            const nextChar = current[placeholderCharIndex] || "";
            delay = 42 + Math.random() * 72;

            if (lastChar === " ") delay += 70 + Math.random() * 70;
            if (/[,.:;!?]/.test(lastChar)) delay += 160 + Math.random() * 120;
            if (nextChar === " ") delay += Math.random() * 45;
            if (Math.random() < 0.08) delay += 90 + Math.random() * 180;
          }

          placeholderTimeout = window.setTimeout(typePlaceholder, delay);
        }

        if (prefersReducedMotion) {
          explorerInput.placeholder = placeholders[0];
        } else {
          explorerInput.placeholder = "";
          typePlaceholder();
        }

        async function fetchExplorerResponse(query) {
          // Static Astro build: keep the explorer fully client-side.
          return getResponse(query);
        }

        async function handleQuery(query) {
          if (!query.trim()) return;
          explorerResponse.classList.remove("hidden");
          explorerResponse.innerHTML = renderLoading();

          const [resp] = await Promise.all([
            fetchExplorerResponse(query),
            new Promise((resolve) => setTimeout(resolve, 450)),
          ]);
          explorerResponse.innerHTML = renderResponse(resp);
          document
            .getElementById("try-another")
            ?.addEventListener("click", () => {
              explorerInput.value = "";
              explorerInput.focus();
              explorerResponse.classList.add("hidden");
              explorerResponse.innerHTML = "";
            });
        }

        explorerForm.addEventListener("submit", (e) => {
          e.preventDefault();
          handleQuery(explorerInput.value);
        });

        // Chips
        document.querySelectorAll(".chip").forEach((chip) => {
          chip.addEventListener("click", () => {
            explorerInput.value = chip.dataset.q;
            handleQuery(chip.dataset.q);
          });
        });

        // ── SECTION SCROLL ANIMATIONS ────────────────────────────────

        // Service cards
        gsap.utils.toArray(".service-card").forEach((el, i) => {
          gsap.to(el, {
            opacity: 1,
            y: 0,
            duration: 0.7,
            ease: "power3.out",
            delay: i * 0.1,
            scrollTrigger: {
              trigger: el,
              start: "top 88%",
              toggleActions: "play none none none",
            },
          });
        });

        // Use case cards
        gsap.utils.toArray(".case-card").forEach((el, i) => {
          gsap.to(el, {
            opacity: 1,
            y: 0,
            duration: 0.65,
            ease: "power3.out",
            delay: (i % 3) * 0.08,
            scrollTrigger: {
              trigger: el,
              start: "top 90%",
              toggleActions: "play none none none",
            },
          });
        });

        const caseDetail = document.getElementById("case-detail");
        const caseCards = gsap.utils.toArray(".case-card");
        const CASE_VIDEOS = {
          "Uploaded document analysis": {
            src: "./media/use-cases/01-real-estate-dossier.mov",
          },
          "Lead scoring and CRM enrichment": {
            src: "./media/use-cases/02-lead-qualification.mov",
          },
          "Smart request routing and triage": {
            src: "./media/use-cases/03-legal-case-routing.mov",
          },
          "Unstructured content into structured product data": {
            src: "./media/use-cases/04-recipe-ai-ingestion.mov",
          },
        };

        function extractCaseData(card) {
          const category =
            card.querySelector(".case-tag")?.textContent.trim() || "";
          const title = card.querySelector("h3")?.textContent.trim() || "";
          const items = {
            problem: "",
            system: "",
            outcome: "",
          };

          card.querySelectorAll(".case-row-item").forEach((item) => {
            const label = item.querySelector(".label")?.textContent.trim();
            const text = item.querySelector("p")?.textContent.trim() || "";
            if (label === "Problem") items.problem = text;
            if (label === "What the system does") items.system = text;
            if (label === "Business outcome") items.outcome = text;
          });

          return {
            category,
            title,
            ...items,
            video: CASE_VIDEOS[title] || null,
          };
        }

        function renderCaseMedia(detail) {
          if (!detail.video?.src) return "";

          return `
            <div class="case-detail-media">
              <div class="case-detail-video-frame">
                <video
                  autoplay
                  loop
                  muted
                  playsinline
                  preload="metadata"
                  aria-label="${escapeHtml(detail.title)} demo video"
                >
                  <source src="${escapeHtml(detail.video.src)}" />
                </video>
              </div>
            </div>
          `;
        }

        function renderCaseDetail(card) {
          if (!caseDetail || !card) return;

          caseCards.forEach((item) => {
            const isActive = item === card;
            item.classList.toggle("is-active", isActive);
            item.setAttribute("aria-selected", String(isActive));
          });

          const detail = extractCaseData(card);

          caseDetail.classList.remove("is-visible");
          caseDetail.innerHTML = `
            <div class="case-detail-head">
              <span class="case-detail-tag">${escapeHtml(detail.category)}</span>
              <h3 class="case-detail-title">${escapeHtml(detail.title)}</h3>
            </div>
            <div class="case-detail-grid">
              <div class="case-row-item">
                <div class="label">Problem</div>
                <p>${escapeHtml(detail.problem)}</p>
              </div>
              <div class="case-row-item">
                <div class="label">What the system does</div>
                <p>${escapeHtml(detail.system)}</p>
              </div>
              <div class="case-row-item case-outcome">
                <div class="label">Business outcome</div>
                <p>${escapeHtml(detail.outcome)}</p>
              </div>
              ${renderCaseMedia(detail)}
            </div>
          `;
          requestAnimationFrame(() => {
            caseDetail.classList.add("is-visible");
            const video = caseDetail.querySelector("video");
            video?.play?.().catch(() => {});
          });
        }

        caseCards.forEach((card, i) => {
          card.setAttribute("role", "button");
          card.setAttribute("tabindex", "0");
          card.setAttribute("aria-selected", i === 0 ? "true" : "false");
          card.addEventListener("click", () => renderCaseDetail(card));
          card.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            renderCaseDetail(card);
          });
        });
        renderCaseDetail(caseCards[0]);

        // Process steps
        gsap.utils.toArray(".step").forEach((el, i) => {
          const icon = el.querySelector(".step-bg-icon");
          const paths = el.querySelectorAll(".step-bg-icon path");
          const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;

          const revealTl = gsap.timeline({
            scrollTrigger: {
              trigger: el,
              start: "top 88%",
              toggleActions: "play none none none",
            },
          });

          revealTl.to(el, {
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: "power3.out",
            delay: (i % 3) * 0.1,
          });

          if (reduceMotion || !icon || !paths.length) return;

          revealTl.fromTo(
            paths,
            {
              strokeDasharray: (_, path) => path.getTotalLength(),
              strokeDashoffset: (_, path) => path.getTotalLength(),
            },
            {
              strokeDashoffset: 0,
              duration: 1,
              stagger: 0.07,
              ease: "power2.out",
            },
            "-=0.25",
          );

          const motionTl = gsap.timeline({
            paused: true,
            repeat: -1,
            yoyo: true,
            defaults: { ease: "sine.inOut" },
          });

          const q = gsap.utils.selector(el);
          const stepAnimations = [
            () => {
              motionTl
                .to(q(".svg-frame"), { scale: 1.035, duration: 1.6 }, 0)
                .to(
                  q(".svg-lines"),
                  { x: 5, opacity: 0.72, duration: 1.15 },
                  0.1,
                )
                .to(
                  q(".svg-sparks"),
                  { scale: 1.35, opacity: 1, duration: 0.75 },
                  0.28,
                );
            },
            () => {
              motionTl
                .to(q(".svg-outer"), { rotate: 3, duration: 1.9 }, 0)
                .to(
                  q(".svg-inner"),
                  { scale: 1.12, opacity: 1, duration: 1.15 },
                  0,
                )
                .to(
                  q(".svg-axis"),
                  { scale: 0.9, opacity: 0.62, duration: 1.15 },
                  0.15,
                );
            },
            () => {
              motionTl
                .to(q(".svg-node-a"), { x: -4, y: -3, duration: 1.25 }, 0)
                .to(q(".svg-node-b"), { x: 4, y: -3, duration: 1.25 }, 0.12)
                .to(q(".svg-node-c"), { x: -4, y: 3, duration: 1.25 }, 0.24)
                .to(q(".svg-node-d"), { x: 4, y: 3, duration: 1.25 }, 0.36)
                .to(
                  q(".svg-core"),
                  { scale: 1.12, opacity: 1, duration: 1 },
                  0.18,
                );
            },
            () => {
              motionTl
                .to(q(".svg-orbit"), { rotate: 10, duration: 2.4 }, 0)
                .to(
                  q(".svg-plus"),
                  { scale: 1.16, opacity: 1, duration: 0.9 },
                  0.18,
                )
                .to(
                  q(".svg-corners"),
                  { scale: 0.86, opacity: 0.58, duration: 1.25 },
                  0.3,
                );
            },
            () => {
              motionTl
                .to(
                  q(".svg-target-outer"),
                  { scale: 1.05, opacity: 0.82, duration: 1.45 },
                  0,
                )
                .to(
                  q(".svg-target-mid"),
                  { scale: 0.93, opacity: 1, duration: 1.45 },
                  0.1,
                )
                .to(
                  q(".svg-target-dot"),
                  { scale: 1.4, opacity: 1, duration: 0.75 },
                  0.22,
                )
                .to(
                  q(".svg-target-marks"),
                  { rotate: 5, opacity: 0.65, duration: 1.45 },
                  0,
                );
            },
            () => {
              motionTl
                .to(
                  q(".svg-arrow-stem"),
                  { x: 5, y: -5, opacity: 1, duration: 1.1 },
                  0,
                )
                .to(
                  q(".svg-arrow-head"),
                  { x: 5, y: -5, scale: 1.04, duration: 1.1 },
                  0,
                )
                .to(
                  q(".svg-lock"),
                  { y: -5, opacity: 0.72, duration: 1.1 },
                  0.2,
                )
                .to(
                  q(".svg-ground"),
                  { scaleX: 0.92, opacity: 0.6, duration: 1.1 },
                  0.1,
                );
            },
          ];

          stepAnimations[i]?.();

          ScrollTrigger.create({
            trigger: el,
            start: "top 70%",
            end: "bottom 30%",
            onEnter: () => motionTl.play(),
            onEnterBack: () => motionTl.play(),
            onLeave: () => motionTl.pause(),
            onLeaveBack: () => motionTl.pause(),
          });
        });

        // Section headers
        gsap.utils.toArray(".section-header").forEach((el) => {
          gsap.from(el, {
            opacity: 0,
            y: 30,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: el,
              start: "top 85%",
              toggleActions: "play none none none",
            },
          });
        });

        // CTA section
        gsap.from("#contact .container", {
          opacity: 0,
          y: 40,
          duration: 1,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#contact",
            start: "top 75%",
            toggleActions: "play none none none",
          },
        });

        // Hero content entrance
        gsap.from(".hero-label", {
          opacity: 0,
          y: 16,
          duration: 0.7,
          delay: 0.3,
          ease: "power3.out",
        });
        gsap.from(".hero-title", {
          opacity: 0,
          y: 24,
          duration: 0.8,
          delay: 0.5,
          ease: "power3.out",
        });
        gsap.from(".hero-sub", {
          opacity: 0,
          y: 20,
          duration: 0.7,
          delay: 0.75,
          ease: "power3.out",
        });
        gsap.from(".explorer", {
          opacity: 0,
          y: 24,
          duration: 0.8,
          delay: 0.95,
          ease: "power3.out",
        });
        gsap.from(".scroll-hint", {
          opacity: 0,
          duration: 1,
          delay: 1.8,
          ease: "power2.out",
        });
      })();
    </script>
    <script is:inline>
      // ── MOBILE DRAWER ────────────────────────────────────────────
      (() => {
        const menuBtn = document.getElementById('nav-menu-btn');
        const drawer = document.getElementById('nav-drawer');
        const closeBtn = document.getElementById('nav-drawer-close');

        function openDrawer() {
          drawer.classList.add('is-open');
          drawer.setAttribute('aria-hidden', 'false');
          closeBtn?.classList.add('is-visible');
          closeBtn?.setAttribute('aria-hidden', 'false');
          menuBtn.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        }

        function closeDrawer() {
          drawer.classList.remove('is-open');
          drawer.setAttribute('aria-hidden', 'true');
          closeBtn?.classList.remove('is-visible');
          closeBtn?.setAttribute('aria-hidden', 'true');
          menuBtn.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        }

        menuBtn?.addEventListener('click', openDrawer);
        closeBtn?.addEventListener('click', closeDrawer);

        drawer?.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeDrawer);
        });

        drawer?.addEventListener('click', (e) => {
          if (e.target === drawer) closeDrawer();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && drawer?.classList.contains('is-open')) closeDrawer();
        });
      })();
    </script>
</BaseLayout>
