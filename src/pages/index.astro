    <script is:inline>
      (() => {
        "use strict";

        if (window.location.protocol === "file:") {
          document.querySelectorAll("[data-local-href]").forEach((link) => {
            link.setAttribute("href", link.getAttribute("data-local-href"));
          });
        }

        // ── GSAP SETUP ───────────────────────────────────────────────
        gsap.registerPlugin(ScrollTrigger);

        // ── PALETTE TOGGLE ──────────────────────────────────────────
        const root = document.documentElement;
        const paletteToggle = document.getElementById("palette-toggle");
        const paletteStorageKey = "portfolio-palette-v2";
        let themeCanvasBg = "#141210";

        function refreshThemeVars() {
          const styles = getComputedStyle(root);
          themeCanvasBg =
            styles.getPropertyValue("--canvas-bg").trim() || "#141210";
        }

        function setPalette(palette) {
          const isWarm = palette === "warm";
          if (isWarm) {
            root.dataset.palette = "warm";
          } else {
            delete root.dataset.palette;
          }

          if (paletteToggle) {
            paletteToggle.setAttribute("aria-pressed", String(isWarm));
            paletteToggle.setAttribute(
              "aria-label",
              isWarm ? "Switch to dark palette" : "Switch to light palette",
            );
          }

          refreshThemeVars();
        }

        let savedPalette = "warm";
        try {
          savedPalette = localStorage.getItem(paletteStorageKey) || "warm";
        } catch (error) {
          savedPalette = "warm";
        }
        setPalette(savedPalette === "warm" ? "warm" : "current");

        paletteToggle?.addEventListener("click", () => {
          const nextPalette =
            root.dataset.palette === "warm" ? "current" : "warm";
          setPalette(nextPalette);
          try {
            localStorage.setItem(paletteStorageKey, nextPalette);
          } catch (error) {
            // Palette preference is optional.
          }
        });

        // ── CUSTOM CURSOR ────────────────────────────────────────────
        const customCursor = document.querySelector(".custom-cursor");
        if (customCursor && window.matchMedia("(pointer: fine)").matches) {
          window.addEventListener("mousemove", (e) => {
            customCursor.classList.add("is-visible");
            customCursor.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0) translate(-50%, -50%)`;
          });

          window.addEventListener("mouseleave", () => {
            customCursor.classList.remove("is-visible");
          });

          document.querySelectorAll("a, button, input").forEach((el) => {
            el.addEventListener("mouseenter", () =>
              customCursor.classList.add("is-hovering"),
            );
            el.addEventListener("mouseleave", () =>
              customCursor.classList.remove("is-hovering"),
            );
          });
        }

        // ── NAVIGATION SCROLL ───────────────────────────────────────
        const nav = document.getElementById("nav");
        const scrollHint = document.querySelector(".scroll-hint");
        const cornerWordmarkPath = document.getElementById(
          "corner-wordmark-path",
        );
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        const wordmarkRailStart =
          "M 58 560 L 58 480 C 58 400 58 300 58 220 C 58 220 58 220 58 220 L 58 220";
        const wordmarkRailEnd =
          "M 58 214 L 58 158 C 58 94 108 48 190 48 C 238 48 292 48 344 48 L 532 48";

        if (cornerWordmarkPath) {
          if (prefersReducedMotion) {
            gsap.set(cornerWordmarkPath, { attr: { d: wordmarkRailEnd } });
          } else {
            gsap.set(cornerWordmarkPath, { attr: { d: wordmarkRailStart } });
            gsap.to(cornerWordmarkPath, {
              attr: { d: wordmarkRailEnd },
              ease: "none",
              scrollTrigger: {
                start: 0,
                end: 180,
                scrub: 0.55,
              },
            });
          }
        }

        ScrollTrigger.create({
          start: 60,
          onUpdate: (self) => {
            nav.classList.toggle("scrolled", self.scroll() > 60);
            scrollHint?.classList.toggle("is-hidden", self.scroll() > 4);
          },
        });

        const navSectionLinks = gsap.utils.toArray(".nav-links a[href^='#']");
        function setActiveNavLink(id) {
          navSectionLinks.forEach((link) => {
            link.classList.toggle(
              "is-active",
              link.getAttribute("href") === `#${id}`,
            );
          });
        }

        ["what", "cases", "process", "contact"].forEach((id) => {
          const section = document.getElementById(id);
          if (!section) return;

          ScrollTrigger.create({
            trigger: section,
            start: "top center",
            end: "bottom center",
            onEnter: () => setActiveNavLink(id),
            onEnterBack: () => setActiveNavLink(id),
          });
        });

        // ── IMMERSIVE STARFIELD ENGINE ─────────────────────────────

        const canvas = document.getElementById("starfield");
        const ctx = canvas.getContext("2d");
        const stickersContainer = document.getElementById("stickers");
        const heroContent = document.querySelector(".hero-content");
        const heroPhase1 = document.getElementById("hero-phase-1");
        const explorerLayer = document.getElementById("ai-explorer");

        // Working dimensions (CSS pixels, not canvas pixels)
        let W = window.innerWidth;
        let H = window.innerHeight;

        let cameraZ = 0; // driven by scroll
        let mouseX = 0; // -1..1
        let mouseY = 0;
        let smoothMouseX = 0;
        let smoothMouseY = 0;
        let particles = [];
        let stickerEls = [];
        let rafId = null;
        let frameTime = 0;

        // ── CONSTANTS ──────────────────────────────────────────────
        const FOV = 280; // perspective strength — lower = more dramatic
        const NUM_PART = 480; // particle count
        const HALF_SPREAD = 900; // half-width of the particle volume (3D units)
        const DEPTH = 1800; // total z-depth
        const CAMERA_RANGE = 1400; // camera travel distance over full scroll
        const PARALLAX_STR = 28; // mouse parallax max offset (px)
        const STICKER_DRIFT_SPEED = 0.42; // z-units per frame, keeps examples alive while static

        // ── STICKER 3D LAYOUT ──────────────────────────────────────
        // Kept wide (|x|,|y| > 200) so they orbit around center content
        const STICKER_DATA = [
          { label: "AI lead scoring", x: -380, y: -300, z: 200 },
          { label: "Telegram alerts", x: 420, y: -200, z: 300 },
          { label: "WhatsApp workflows", x: -450, y: 240, z: 420 },
          { label: "Smart summaries", x: 400, y: 310, z: 520 },
          { label: "Document parsing", x: -520, y: -120, z: 620 },
          { label: "CRM enrichment", x: 300, y: -400, z: 710 },
          { label: "Internal copilot", x: -220, y: 430, z: 800 },
          { label: "Admin-side AI", x: 500, y: -160, z: 880 },
          { label: "Semantic search", x: -480, y: 160, z: 960 },
          { label: "Ticket triage", x: 360, y: 380, z: 1040 },
          { label: "Email drafting", x: -140, y: -460, z: 1120 },
          { label: "Meeting summaries", x: 460, y: 90, z: 1200 },
          { label: "Workflow automation", x: -420, y: 40, z: 1280 },
          { label: "Actionable notifications", x: 220, y: -300, z: 1360 },
        ];

        // ── CANVAS SIZING ──────────────────────────────────────────
        // Use window dimensions directly — most reliable cross-browser
        function resizeCanvas() {
          W = window.innerWidth;
          H = window.innerHeight;
          canvas.width = W;
          canvas.height = H;
        }

        // ── PARTICLE FACTORY ──────────────────────────────────────
        function makeParticle(initPhase) {
          // Uniform random in a square volume — simple and reliable
          return {
            x: (Math.random() - 0.5) * HALF_SPREAD * 2,
            y: (Math.random() - 0.5) * HALF_SPREAD * 2,
            // On init spread across full depth; on respawn come from far end
            z: initPhase ? Math.random() * DEPTH : DEPTH - Math.random() * 120,
            // Size: bigger than you think — they'll be scaled down by distance
            r: 1.2 + Math.random() * 2.2,
            // Blue-white spectrum — slightly warm near-particles, cool far ones
            hue: 210 + Math.floor(Math.random() * 55),
            sat: 15 + Math.floor(Math.random() * 45),
            lit: 62 + Math.floor(Math.random() * 32),
            // tiny drift per frame
            dx: (Math.random() - 0.5) * 0.12,
            dy: (Math.random() - 0.5) * 0.1,
          };
        }

        function initParticles() {
          particles = Array.from({ length: NUM_PART }, () =>
            makeParticle(true),
          );
        }

        // ── PROJECTION ────────────────────────────────────────────
        function project(p) {
          const dz = ((p.z - cameraZ + DEPTH) % DEPTH) + 1;
          if (dz < 1) return null;
          const s = FOV / dz;
          return {
            x: p.x * s + W * 0.5 + smoothMouseX * PARALLAX_STR * Math.min(1, s),
            y: p.y * s + H * 0.5 + smoothMouseY * PARALLAX_STR * Math.min(1, s),
            s, // perspective scale
            r: p.r * s, // projected radius (gets bigger when close)
          };
        }

        // ── DRAW ──────────────────────────────────────────────────
        function draw() {
          // Full clear each frame — reliable, no artifacts
          ctx.clearRect(0, 0, W, H);

          // Dark background fill
          ctx.fillStyle = themeCanvasBg;
          ctx.fillRect(0, 0, W, H);

          // Drift update + sort far→near
          frameTime++;
          for (const p of particles) {
            p.x += p.dx;
            p.y += p.dy;
            // gentle sinusoidal wander
            p.x += Math.sin(frameTime * 0.0004 + p.z * 0.002) * 0.05;
            p.y += Math.cos(frameTime * 0.0003 + p.z * 0.002) * 0.04;
          }
          particles.sort((a, b) => b.z - a.z);

          for (const p of particles) {
            const pr = project(p);

            if (!pr || pr.s > 8) continue;

            const dz = ((p.z - cameraZ + DEPTH) % DEPTH) + 1;
            const isLightPalette = root.dataset.palette === "warm";
            const particleHue = isLightPalette ? 24 + (p.hue % 18) : p.hue;
            const particleSat = isLightPalette ? 58 + (p.sat % 18) : p.sat;
            const particleLit = isLightPalette ? 30 + (p.lit % 18) : p.lit;

            // ── Visibility ──────────────────────────────────────
            // Particles fade in from far, are full opacity mid-range, fade on approach
            let alpha;
            const FAR_FADE = DEPTH * 0.55;
            const NEAR_FADE = 60;
            if (dz > FAR_FADE) {
              alpha = (1 - (dz - FAR_FADE) / (DEPTH - FAR_FADE)) * 0.5;
            } else if (dz < NEAR_FADE) {
              alpha = (dz / NEAR_FADE) * 0.7;
            } else {
              // Core zone: opacity scales with proximity — nearer = brighter
              alpha = Math.min(0.82, 0.22 + pr.s * 0.55);
            }

            if (alpha < 0.02) continue; // skip invisible

            // ── Dot radius: clamp so distant dots stay 1 px minimum ─
            const dotR = Math.max(0.55, Math.min(pr.r, 4.5));

            // Subtle glow for nearer particles
            if (pr.s > 0.7 && dotR > 1.2) {
              const grad = ctx.createRadialGradient(
                pr.x,
                pr.y,
                0,
                pr.x,
                pr.y,
                dotR * 3.5,
              );
              grad.addColorStop(
                0,
                `hsla(${particleHue},${particleSat}%,${particleLit}%,${(alpha * 0.18).toFixed(3)})`,
              );
              grad.addColorStop(1, "transparent");
              ctx.fillStyle = grad;
              ctx.beginPath();
              ctx.arc(pr.x, pr.y, dotR * 3.5, 0, Math.PI * 2);
              ctx.fill();
            }

            // Core dot
            ctx.globalAlpha = alpha;
            ctx.fillStyle = `hsl(${particleHue},${particleSat}%,${particleLit}%)`;
            ctx.beginPath();
            ctx.arc(pr.x, pr.y, dotR, 0, Math.PI * 2);
            ctx.fill();
          }

          ctx.globalAlpha = 1;
        }

        // ── STICKERS ──────────────────────────────────────────────
        function buildStickers() {
          STICKER_DATA.forEach((s) => {
            const el = document.createElement("div");
            el.className = "sticker";
            el.textContent = s.label;
            stickersContainer.appendChild(el);
            stickerEls.push(el);
          });
        }

        function updateStickers() {
          const progress = Math.min(1, Math.max(0, cameraZ / CAMERA_RANGE));
          const calmFactor = progress > 0.58 ? 0.62 : 1;

          STICKER_DATA.forEach((s, i) => {
            const el = stickerEls[i];
            const wobble = Math.sin(frameTime * 0.006 + i * 1.7) * 42;
            const driftSpeed = STICKER_DRIFT_SPEED * (0.62 + (i % 5) * 0.16);
            const animatedZ =
              (s.z - frameTime * driftSpeed + wobble + DEPTH) % DEPTH;
            const stickerPoint = {
              ...s,
              x: s.x + Math.sin(frameTime * 0.003 + i) * 18,
              y: s.y + Math.cos(frameTime * 0.0025 + i * 1.3) * 14,
              z: animatedZ,
            };
            const dz = ((stickerPoint.z - cameraZ + DEPTH) % DEPTH) + 1;

            const pr = project(stickerPoint);
            if (!pr) {
              el.style.opacity = "0";
              return;
            }

            // Visible window: 500 → 60 depth units from camera
            let alpha = 0;
            if (dz < 500 && dz > 60) {
              alpha =
                Math.min(1, (500 - dz) / 220) *
                Math.min(1, (dz - 60) / 90) *
                0.95;
            }
            if (progress > 0.58 && i % 3 === 1) alpha *= 0.18;
            alpha *= calmFactor;
            // cull off-screen
            if (pr.x < -100 || pr.x > W + 100 || pr.y < -60 || pr.y > H + 60)
              alpha = 0;

            const sc = Math.min(
              1.22,
              Math.max(0.62, pr.s * (progress > 0.58 ? 0.64 : 0.76)),
            );

            el.style.opacity = alpha.toFixed(3);
            el.style.transform = `translate(${pr.x.toFixed(1)}px,${pr.y.toFixed(1)}px) translate(-50%,-50%) scale(${sc.toFixed(3)})`;
          });
        }

        // ── HERO CONTENT FADE ON SCROLL ──────────────────────────
        function updateHeroFade() {
          const p = Math.min(1, Math.max(0, cameraZ / CAMERA_RANGE)); // 0..1
          // The central hero sentence must fully disappear before the explorer can receive focus.
          const titleAlpha = Math.max(0, 1 - p * 3.2);
          const titleScale = 1 - p * 0.12;
          heroPhase1.style.opacity = titleAlpha.toFixed(3);
          heroPhase1.style.transform = `scale(${Math.max(0.88, titleScale).toFixed(3)})`;

          const explorerAlpha = Math.max(0, Math.min(1, (p - 0.36) / 0.16));
          if (p < 0.34) {
            explorerLayer.style.opacity = "0";
            explorerLayer.style.transform = "translateY(22px) scale(0.98)";
            explorerLayer.classList.remove("is-active");
            explorerLayer.setAttribute("aria-hidden", "true");
            heroContent.style.opacity = "1";
            heroContent.style.transform = "none";
            return;
          }
          explorerLayer.style.opacity = explorerAlpha.toFixed(3);
          explorerLayer.style.transform = `translateY(${((1 - explorerAlpha) * 22).toFixed(1)}px) scale(${(0.98 + explorerAlpha * 0.02).toFixed(3)})`;
          explorerLayer.classList.toggle("is-active", explorerAlpha > 0.82);
          explorerLayer.setAttribute(
            "aria-hidden",
            explorerAlpha > 0.05 ? "false" : "true",
          );
          heroContent.style.opacity = "1";
          heroContent.style.transform = "none";
        }

        // ── MOUSE ─────────────────────────────────────────────────
        window.addEventListener("mousemove", (e) => {
          mouseX = (e.clientX / W - 0.5) * 2;
          mouseY = (e.clientY / H - 0.5) * 2;
        });

        // ── MAIN LOOP ─────────────────────────────────────────────
        function tick() {
          smoothMouseX += (mouseX - smoothMouseX) * 0.05;
          smoothMouseY += (mouseY - smoothMouseY) * 0.05;
          draw();
          updateStickers();
          updateHeroFade();
          rafId = requestAnimationFrame(tick);
        }

        function init() {
          resizeCanvas();
          initParticles();
          buildStickers();
          if (rafId) cancelAnimationFrame(rafId);
          tick();
        }

        // ── SCROLL → CAMERA (GSAP) ────────────────────────────────
        ScrollTrigger.create({
          trigger: "#hero-wrapper",
          start: "top top",
          end: "bottom top",
          onUpdate(self) {
            cameraZ = self.progress * CAMERA_RANGE;
          },
        });

        window.addEventListener("resize", () => {
          resizeCanvas();
        });

        // Init after a tick so layout is computed
        requestAnimationFrame(init);

        // ── AI SOLUTION EXPLORER ─────────────────────────────────────

        const RESPONSES = {
